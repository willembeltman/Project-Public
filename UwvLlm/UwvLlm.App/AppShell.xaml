<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="UwvLlm.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:UwvLlm.App.Pages"
    Title="UwvLlm.App">
    
    <Shell.TitleView>
        <Grid>
            <Label Text="Mijn App" HorizontalOptions="Start" />

            <Grid HorizontalOptions="End">
                <Image Source="bell.png" WidthRequest="24" HeightRequest="24" />

                <Border
                    BackgroundColor="Red"
                    Padding="2"
                    IsVisible="{Binding HasNotifications}"
                    HorizontalOptions="End"
                    VerticalOptions="Start">

                    <Label
                        Text="{Binding NotificationCount}"
                        FontSize="10"
                        TextColor="White" />
                </Border>
            </Grid>
        </Grid>
    </Shell.TitleView>

    <ShellContent
        Title="Main"
        ContentTemplate="{DataTemplate local:LoginPage}" />

</Shell>
